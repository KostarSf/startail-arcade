{
  "name": "bun-react-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "dev:debug": "bun --hot src/index.ts --debug-performance",
    "start": "NODE_ENV=production bun src/index.ts",
    "build": "bun run build.ts",
    "test": "bun test tests/unit",
    "test:e2e": "playwright test",
    "test:install-browsers": "playwright install chromium",
    "probe:agent": "node scripts/run-agent-probe.mjs",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint --type-aware src build.ts"
  },
  "dependencies": {
    "bun-plugin-tailwind": "^0.1.2",
    "pixi.js": "^8.14.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.1.17",
    "unique-names-generator": "^4.7.1",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@types/bun": "latest",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "^7.0.0-dev.20260409.1",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "oxlint-tsgolint": "^0.20.0"
  }
}
